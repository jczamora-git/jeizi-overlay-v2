# Local MySQL
DB_CLIENT=mysql
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=jeizi_overlay
MYSQL_PORT=3306

# Legacy local aliases still supported by the adapter
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jeizi_overlay
DB_USER=root
DB_PASSWORD=

PORT=3000

# Local development
VITE_API_BASE_URL=http://localhost:3000
VITE_ENABLE_SOCKET=true

# Backward-compatible aliases still supported by the frontend config
VITE_API_ORIGIN=http://localhost:3000

# Production Supabase PostgreSQL
# DB_CLIENT=postgres
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Production frontend example
# VITE_API_BASE_URL=https://www.jeiziproductions.dev
# VITE_ENABLE_SOCKET=false
# FRONTEND_URL=https://www.jeiziproductions.dev
